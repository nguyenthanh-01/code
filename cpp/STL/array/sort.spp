#include <bits/stdc++.h>
using namespace std;

#define n 5
#define all(a) (a).begin(), (a).end()

typedef long long ll;

int main() {
    array<int, n> ar;
    for (int &i: ar) {
        cin >> i;
    }
    sort(all(ar));
    for (int &i: ar) {
        printf("%d ", i);
    }
    printf("\n");
    return 0;
}
